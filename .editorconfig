root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{cs,shader,hlsl,cginc,compute}]
indent_style = space
indent_size = 4

[*.{json,asmdef}]
indent_style = space
indent_size = 2

[*.{unity,prefab,asset,meta,mat,anim,controller}]
indent_style = space
indent_size = 2
